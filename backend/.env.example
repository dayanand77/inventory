FLASK_ENV=development
FLASK_SECRET_KEY=change-this-key
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=inventory
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
LOW_STOCK_DEFAULT_THRESHOLD=10
FIREBASE_PROJECT_ID=your-firebase-project-id
# Optional: set this to a secure path outside the repository for local development.
GOOGLE_APPLICATION_CREDENTIALS=
# Optional fallback when you cannot use GOOGLE_APPLICATION_CREDENTIALS:
FIREBASE_SERVICE_ACCOUNT_JSON=
